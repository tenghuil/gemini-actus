{
  "name": "@google/gemini-actus-chat-server",
  "version": "0.1.0",
  "description": "Google Chat Server for Gemini Actus",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/google-gemini/gemini-actus.git",
    "directory": "packages/google-chat-server"
  },
  "type": "module",
  "main": "dist/src/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "NODE_OPTIONS='--no-deprecation' node dist/src/index.js",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@types/node-fetch": "^2.6.13",
    "dotenv": "^16.4.5",
    "express": "^5.1.0",
    "google-auth-library": "^9.6.3",
    "node-fetch": "^3.3.2",
    "uuid": "^9.0.1",
    "winston": "^3.17.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.10",
    "typescript": "^5.3.3",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=20"
  }
}
